---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Sambulo Senda" description="Get in touch about React Native consulting.">
  <div class="page" style="max-width:600px;">
    <div class="page-head">
      <h1 class="page-title">Get in touch</h1>
    </div>

    <p class="contact-lede">
      I'm open to React Native consulting from <strong>Q3 2026</strong> &mdash; architecture audits,
      New Architecture migrations, performance work, or a few weeks embedded with your team.
    </p>
    <p class="contact-sub">
      The fastest way to reach me is email. I read everything; I reply to most.
    </p>

    <div>
      <a class="post-row" href="mailto:sambulosendas@gmail.com">
        <span class="pr-left"><span class="pr-arrow">&rarr;</span><span class="pr-title">Email</span></span>
        <span class="pr-right"><span class="pr-date">sambulosendas@gmail.com</span></span>
      </a>
      <a class="post-row" href="https://github.com/sambulosenda">
        <span class="pr-left"><span class="pr-arrow">&rarr;</span><span class="pr-title">GitHub</span></span>
        <span class="pr-right"><span class="pr-date">@sambulosenda</span></span>
      </a>
      <a class="post-row" href="https://twitter.com/sambulosenda">
        <span class="pr-left"><span class="pr-arrow">&rarr;</span><span class="pr-title">X / Twitter</span></span>
        <span class="pr-right"><span class="pr-date">@sambulosenda</span></span>
      </a>
    </div>
  </div>
</Layout>
