---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { socialLinks } from '../data/projects';
---

<Layout title="About — Sambulo Senda" description="Mobile engineer, indie app maker, and consultant helping teams ship React Native apps.">
  <main class="min-h-screen">

    <section class="pt-36 pb-16 sm:pt-44">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">

        <div class="flex items-center gap-5 mb-8">
          <img
            src="/profile.jpg"
            alt="Sambulo Senda"
            class="w-20 h-20 rounded-full object-cover"
          />
          <div>
            <h1 class="text-2xl font-bold text-ink tracking-tight">Sambulo Senda</h1>
            <p class="text-ink-muted mt-1">Mobile Engineer & Consultant</p>
          </div>
        </div>

        <div class="space-y-4 text-ink-muted leading-relaxed">
          <p>
            I'm a React Native engineer with 5+ years of experience building and shipping mobile apps. I've built everything from Bible apps to AI-powered OCR tools to EV charging platforms.
          </p>
          <p>
            I build indie products, help teams migrate to React Native's New Architecture, and write about the things I learn along the way. My work sits at the intersection of mobile engineering, product thinking, and shipping fast.
          </p>
          <p>
            When I'm not coding, I'm usually exploring new AI tools, reading about product strategy, or working on my next side project.
          </p>
        </div>

        <div class="mt-10 pt-8 border-t border-border">
          <h2 class="text-sm font-medium text-ink-faint uppercase tracking-wider mb-4">How to work with me</h2>
          <div class="space-y-3 text-sm text-ink-muted">
            <p><strong class="text-ink">Consulting:</strong> I help teams ship React Native apps faster. Architecture reviews, performance audits, and hands-on development.</p>
            <p><strong class="text-ink">Indie apps:</strong> I build and maintain my own apps on the App Store. Check out my <a href="/projects" class="text-accent hover:underline">projects</a>.</p>
            <p><strong class="text-ink">Writing:</strong> I write about React Native, mobile development, and the tools I use. Read my <a href="/writing" class="text-accent hover:underline">blog</a>.</p>
          </div>
        </div>

        <div class="mt-10 pt-8 border-t border-border">
          <h2 class="text-sm font-medium text-ink-faint uppercase tracking-wider mb-4">Get in touch</h2>
          <div class="flex items-center gap-4">
            <a
              href="https://cal.com/sambulosenda"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-ink text-surface rounded-lg hover:opacity-90 transition-opacity"
            >
              Book a call
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <div class="flex items-center gap-0.5">
              {socialLinks.map(({ url, platform, icon }) => (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="p-2 text-ink-faint hover:text-ink transition-colors"
                  aria-label={platform}
                >
                  <span set:html={icon} />
                </a>
              ))}
            </div>
          </div>
        </div>

      </div>
    </section>

    <Footer />

  </main>
</Layout>
