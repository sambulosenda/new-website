---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const allPosts = await Astro.glob('./blog/*.{md,mdx}');
const recent = allPosts
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf())
  .slice(0, 6);

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<Layout
  title="Sambulo Senda — Mobile engineer in London"
  description="Mobile engineer based in London. Writing about React Native — offline sync, performance, native modules."
>
  <main class="max-w-2xl mx-auto px-6 pt-20 sm:pt-24">

    <!-- Hero -->
    <section class="pb-16 border-b border-border-muted">
      <div class="reveal inline-flex items-center gap-2 text-xs text-ink-muted bg-surface-muted border border-border-muted px-3 py-1 rounded-full mb-6 font-mono whitespace-nowrap" style="--i: 0">
        <span class="hero-pulse"></span>
        Open to consulting · Q3 2026
      </div>
      <h1 class="reveal font-sans text-3xl font-semibold text-ink tracking-tight mb-6" style="--i: 1">
        Sambulo Senda
      </h1>
      <div class="reveal space-y-5 text-lg text-ink-muted leading-relaxed" style="--i: 2">
        <p>
          I'm a mobile engineer based in London. I work mostly in
          <span class="text-ink font-medium">React Native</span>, and I write about the bits I keep running into: offline sync, performance on older devices, native modules, the New Architecture.
        </p>
        <p>
          Five years in. A few apps in the App Store. Notes go up here when I get the time.
        </p>
      </div>
    </section>

    <!-- Recent writing -->
    <section class="reveal mt-14" style="--i: 3">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="font-sans text-xl font-semibold text-ink tracking-tight">Recent writing</h2>
        <a href="/writing" class="text-sm text-ink-faint hover:text-accent transition-colors">All posts →</a>
      </div>
      <ul class="list-none p-0 m-0">
        {recent.map((p) => (
          <li>
            <a href={p.url} class="group flex items-baseline justify-between gap-4 py-3 border-b border-border-muted last:border-0">
              <span class="text-[15px] text-ink group-hover:text-accent transition-colors">
                {p.frontmatter.title}
              </span>
              <time datetime={p.frontmatter.date} class="text-xs text-ink-faint font-mono tabular-nums whitespace-nowrap">
                {fmtDate(p.frontmatter.date)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Now -->
    <section class="reveal mt-14" id="now" style="--i: 4">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="font-sans text-xl font-semibold text-ink tracking-tight">Now</h2>
        <a href="/now" class="text-xs text-ink-faint hover:text-accent transition-colors whitespace-nowrap">Updated May 2026</a>
      </div>
      <div class="space-y-4 text-base text-ink-muted leading-relaxed">
        <p>
          Writing more than I have in years. Most of it about React Native's New Architecture — Fabric, TurboModules, and the migration work.
        </p>
        <p>
          Reading Tony Fadell's <em class="text-ink italic">Build</em> on the train. Enjoying it so far.
        </p>
        <p>
          Playing with on-device LLM inference on iPhone. Curious how much you can do without a server.
        </p>
      </div>
    </section>

    <!-- Elsewhere -->
    <section class="reveal mt-14 mb-20" style="--i: 5">
      <div class="mb-6">
        <h2 class="font-sans text-xl font-semibold text-ink tracking-tight">Elsewhere</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <a href="mailto:sambulosendas@gmail.com" class="colo-card">
          <span class="colo-label">Email</span>
          <span class="colo-value">sambulosendas@gmail.com</span>
          <span class="colo-arrow">→</span>
        </a>
        <a href="https://github.com/sambulosenda" class="colo-card">
          <span class="colo-label">GitHub</span>
          <span class="colo-value">@sambulosenda</span>
          <span class="colo-arrow">→</span>
        </a>
        <a href="https://twitter.com/sambulosenda" class="colo-card">
          <span class="colo-label">Twitter</span>
          <span class="colo-value">@sambulosenda</span>
          <span class="colo-arrow">→</span>
        </a>
        <a href="/rss.xml" class="colo-card">
          <span class="colo-label">RSS</span>
          <span class="colo-value">/rss.xml</span>
          <span class="colo-arrow">→</span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .hero-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #16a34a;
    box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 18%, transparent);
    animation: hero-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hero-pulse {
    0%, 100% { box-shadow: 0 0 0 3px color-mix(in srgb, #16a34a 18%, transparent); }
    50%      { box-shadow: 0 0 0 6px color-mix(in srgb, #16a34a 0%, transparent); }
  }

  .colo-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 16px 18px;
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border-muted);
    border-radius: 8px;
    transition: border-color .15s, transform .15s;
  }
  .colo-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .colo-card:hover .colo-arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }
  .colo-label {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }
  .colo-value {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 14px;
    color: var(--color-ink);
    font-weight: 500;
  }
  .colo-arrow {
    position: absolute;
    top: 16px;
    right: 18px;
    font-size: 14px;
    color: var(--color-ink-faint);
    transition: color .15s, transform .15s;
  }
</style>
