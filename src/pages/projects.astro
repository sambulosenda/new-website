---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../data/projects';
---

<Layout title="Projects — Sambulo Senda">
  <main>
    <section class="pt-36 pb-20 sm:pt-44">
      <div class="max-w-2xl mx-auto px-4 sm:px-6">

        <header class="mb-10 animate-fade-in-up">
          <h1 class="text-2xl sm:text-3xl font-bold text-ink tracking-tight mb-3">Projects</h1>
          <p class="text-ink-muted">
            Apps I've built and shipped.
          </p>
        </header>

        <div class="space-y-8 animate-fade-in-up-delay-1">
          {projects.map((project) => {
            const Wrapper = project.url ? 'a' : 'div';
            return (
              <Wrapper
                href={project.url}
                target={project.url ? '_blank' : undefined}
                rel={project.url ? 'noopener noreferrer' : undefined}
                class={`group block ${project.url ? 'cursor-pointer' : ''}`}
              >
                <div class="flex flex-col sm:flex-row gap-4">
                  {project.screenshot && (
                    <div class="sm:w-40 shrink-0 overflow-hidden rounded-lg bg-surface-subtle flex items-center justify-center p-3">
                      <img
                        src={project.screenshot}
                        alt={project.title}
                        class="w-full h-full max-h-32 object-contain"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <h3 class="font-medium text-ink group-hover:text-accent transition-colors">
                      {project.title}
                    </h3>
                    <p class="text-sm text-ink-muted mt-1">{project.description}</p>
                    <div class="flex flex-wrap gap-1.5 mt-3">
                      {project.tags.map(tag => (
                        <span class="text-xs px-2 py-0.5 rounded-md bg-surface-subtle text-ink-faint">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </Wrapper>
            );
          })}
        </div>

      </div>
    </section>

    <Footer />
  </main>
</Layout>
