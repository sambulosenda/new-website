---
interface Props {
  question: string;
  chosen: string;
  rejected?: string;
  reason: string;
}

const { question, chosen, rejected, reason } = Astro.props;
---

<div class="not-prose my-8 rounded-lg border border-border bg-surface-subtle p-5">
  <p class="text-xs font-medium text-ink-faint uppercase tracking-wider mb-2">Decision</p>
  <p class="font-medium text-ink mb-3">{question}</p>
  <div class="space-y-2 text-sm">
    <div class="flex items-start gap-2">
      <span class="shrink-0 mt-0.5 w-5 h-5 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center text-xs font-bold">&check;</span>
      <span class="text-ink">{chosen}</span>
    </div>
    {rejected && (
      <div class="flex items-start gap-2">
        <span class="shrink-0 mt-0.5 w-5 h-5 rounded-full bg-red-500/10 text-red-500 dark:text-red-400 flex items-center justify-center text-xs font-bold">&times;</span>
        <span class="text-ink-muted">{rejected}</span>
      </div>
    )}
  </div>
  <p class="text-sm text-ink-muted mt-3 pt-3 border-t border-border">{reason}</p>
</div>
