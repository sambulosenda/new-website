---
const currentPath = Astro.url.pathname;
const isWriting = currentPath.startsWith('/writing') || currentPath.startsWith('/blog');
const isNow = currentPath.startsWith('/now');
---

<nav class="site-nav">
  <a href="/" class="brand">sambulo</a>
  <div class="nav-right">
    <a href="/writing" class:list={['nav-link', isWriting && 'active']}>Writing</a>
    <a href="/now" class:list={['nav-link', isNow && 'active']}>Now</a>
    <button id="theme-toggle" class="nav-icon" aria-label="Toggle theme">
      <svg class="hidden dark:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 3v1M12 20v1M3 12h1M20 12h1M5.6 5.6l.7.7M17.7 17.7l.7.7M5.6 18.4l.7-.7M17.7 6.3l.7-.7"/>
      </svg>
      <svg class="block dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20 15.4A8 8 0 1 1 8.6 4 6.5 6.5 0 0 0 20 15.4z"/>
      </svg>
    </button>
  </div>
</nav>
