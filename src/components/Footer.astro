---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-8 font-sans">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 flex items-center justify-between text-sm text-ink-faint">
    <span>&copy; {year} Sambulo Senda</span>
    <div class="flex items-center gap-4">
      <a href="/rss.xml" class="hover:text-ink transition-colors" aria-label="RSS Feed">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"/>
        </svg>
      </a>
      <button
        id="theme-toggle"
        class="hover:text-ink transition-colors"
        aria-label="Toggle dark mode"
      >
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>
    </div>
  </div>
</footer>
