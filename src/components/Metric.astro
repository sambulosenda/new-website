---
interface Props {
  value: string;
  label: string;
  context?: string;
}

const { value, label, context } = Astro.props;
---

<div class="not-prose inline-flex flex-col items-center p-4 rounded-lg border border-border bg-surface-subtle min-w-[120px] text-center">
  <span class="text-2xl font-bold text-ink tracking-tight">{value}</span>
  <span class="text-xs font-medium text-ink-muted mt-1">{label}</span>
  {context && <span class="text-xs text-ink-faint mt-0.5">{context}</span>}
</div>
