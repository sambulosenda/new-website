---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';

interface Frontmatter {
  title: string;
  date: string;
  tags?: string[];
  description?: string;
  readingTime?: string;
  image?: string;
  type?: 'blog' | 'case-study' | 'decision';
  eyebrow?: string;
  lede?: string;
}

interface Props {
  frontmatter: Frontmatter;
  headings?: { depth: number; slug: string; text: string }[];
}

const { frontmatter } = Astro.props;
const contentType = frontmatter.type || 'blog';
const isCaseStudy = contentType === 'case-study';
const isDecision = contentType === 'decision';

const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const rawContent = await Astro.slots.render('default');
const textOnly = rawContent.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const wordCount = textOnly.split(/\s+/).length;
const minutes = Math.max(1, Math.ceil(wordCount / 230));
const readingTime = frontmatter.readingTime || `${minutes} min`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://sambulosenda.com');

const backLink = isCaseStudy ? '/projects' : isDecision ? '/decisions' : '/writing';
const backLabel = isCaseStudy ? 'All projects' : isDecision ? 'All decisions' : 'All writing';

// Compute prev/next for blog posts (chronological neighbors)
let prev: { url?: string; title: string } | null = null;
let next: { url?: string; title: string } | null = null;
if (contentType === 'blog') {
  const all = await Astro.glob('../pages/blog/*.{md,mdx}');
  const sorted = all.sort((a, b) =>
    new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
  );
  const idx = sorted.findIndex((p) => p.url === Astro.url.pathname.replace(/\/$/, ''));
  if (idx > -1) {
    const p = sorted[idx + 1];
    const n = sorted[idx - 1];
    if (p) prev = { url: p.url, title: p.frontmatter.title };
    if (n) next = { url: n.url, title: n.frontmatter.title };
  }
}

const eyebrow = frontmatter.eyebrow || (frontmatter.tags?.[0]);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": frontmatter.title,
  "description": frontmatter.description || frontmatter.title,
  "datePublished": frontmatter.date,
  "author": { "@type": "Person", "name": "Sambulo Senda", "url": "https://sambulosenda.com" },
  "publisher": { "@type": "Person", "name": "Sambulo Senda" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL.toString() }
};

const slug = Astro.url.pathname.replace(/^\/(blog|case-studies|decisions)\//, '').replace(/\/$/, '');
---

<Layout
  title={`${frontmatter.title} — Sambulo Senda`}
  description={frontmatter.description}
  image={frontmatter.image}
  type="article"
  publishedTime={frontmatter.date}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="max-w-[680px] mx-auto px-6 pt-20 sm:pt-24">

    <a href={backLink} class="article-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      {backLabel}
    </a>

    <header class="article-head">
      {eyebrow && <span class="article-eyebrow">{eyebrow}</span>}
      <h1 class="article-h1">{frontmatter.title}</h1>
      {(frontmatter.lede || frontmatter.description) && (
        <p class="article-lede">{frontmatter.lede || frontmatter.description}</p>
      )}
      <div class="article-meta">
        <time datetime={frontmatter.date}>{formattedDate}</time>
        <span class="dot"></span>
        <span>{readingTime} read</span>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <!-- Clap -->
    <div class="clap">
      <button id="clap-btn" class="clap-button" aria-label="Clap for this post" data-slug={slug}>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 12 6.5 7.5a2 2 0 0 1 2.83-2.83L14 9.34"/>
          <path d="m13 9-1.5-1.5a2 2 0 0 1 2.83-2.83l4.24 4.24"/>
          <path d="m15 7 1-1a2 2 0 1 1 2.83 2.83l-2 2"/>
          <path d="m17 11 .59-.59a2 2 0 1 1 2.83 2.83L17 16.66A6 6 0 0 1 8.76 17l-3-3"/>
          <path d="M14 12.5v0"/>
        </svg>
      </button>
      <div id="clap-count" class="clap-count">0 claps</div>
      <div id="clap-label" class="clap-label">If this was useful, let me know.</div>
    </div>

    {(prev || next) && (
      <div class="article-foot">
        {prev ? (
          <a href={prev.url}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            {prev.title}
          </a>
        ) : <span></span>}
        {next ? (
          <a href={next.url}>
            {next.title}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        ) : <span></span>}
      </div>
    )}
  </main>

  <Footer />
</Layout>

<style is:global>
  .prose {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-ink);
    letter-spacing: -0.003em;
  }
  .prose > * + * { margin-top: 1.4em; }
  .prose p { margin: 0; text-wrap: pretty; }
  .prose h2 {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 22px; font-weight: 600;
    letter-spacing: -0.015em;
    margin: 2.2em 0 0.6em;
    color: var(--color-ink);
  }
  .prose h3 {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 18px; font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2em 0 0.4em;
    color: var(--color-ink);
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    transition: border-color .15s;
  }
  .prose a:hover { border-bottom-color: var(--color-accent); }
  .prose strong { font-weight: 600; color: var(--color-ink); }
  .prose em { font-style: italic; }
  .prose ul, .prose ol { margin: 0; padding-left: 1.4em; }
  .prose li { margin: 0.4em 0; }
  .prose li::marker { color: var(--color-ink-faint); }
  .prose blockquote {
    margin: 0;
    padding: 4px 0 4px 20px;
    border-left: 2px solid var(--color-border);
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .prose code {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 0.86em;
    padding: 2px 6px;
    background: var(--color-surface-subtle);
    border-radius: 4px;
    color: var(--color-ink);
  }
  .prose pre {
    margin: 0;
    padding: 18px 20px;
    background: var(--color-surface-subtle);
    border: 1px solid var(--color-border-muted);
    border-radius: 8px;
    overflow-x: auto;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border-muted);
    margin: 2.4em 0;
  }
  .prose img {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border-muted);
  }
  @media (max-width: 520px) {
    .prose { font-size: 16px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('clap-btn') as HTMLButtonElement | null;
    const countEl = document.getElementById('clap-count');
    const labelEl = document.getElementById('clap-label');
    if (!btn || !countEl || !labelEl) return;

    const slug = btn.dataset.slug || 'post';
    const storageKey = `claps:${slug}`;
    const myKey = `claps-mine:${slug}`;
    const MAX = 50;

    let count = parseInt(localStorage.getItem(storageKey) || '', 10);
    if (!Number.isFinite(count)) {
      count = 24 + (slug.length * 7) % 80;
      localStorage.setItem(storageKey, String(count));
    }
    let mine = parseInt(localStorage.getItem(myKey) || '0', 10) || 0;

    const render = () => {
      countEl.textContent =
        `${count.toLocaleString()} ${count === 1 ? 'clap' : 'claps'}` +
        (mine > 0 ? ` · ${mine} from you` : '');
      labelEl.textContent =
        mine === 0 ? 'If this was useful, let me know.'
        : mine >= MAX ? 'Thanks — that means a lot.'
        : 'Tap up to 50 times.';
      btn.classList.toggle('clapped', mine > 0);
    };
    render();

    btn.addEventListener('click', () => {
      if (mine >= MAX) return;
      mine += 1; count += 1;
      localStorage.setItem(myKey, String(mine));
      localStorage.setItem(storageKey, String(count));
      btn.classList.add('popping');
      setTimeout(() => btn.classList.remove('popping'), 350);

      const burst = document.createElement('span');
      burst.className = 'clap-burst';
      burst.textContent = '+1';
      btn.appendChild(burst);
      setTimeout(() => burst.remove(), 800);

      render();
    });
  });
</script>
