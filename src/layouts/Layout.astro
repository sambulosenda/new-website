---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/newsreader';
import '../styles/scroll-reveal.css';
import '../styles/micro-interactions.css';
import { ViewTransitions } from 'astro:transitions';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description = "Mobile engineer and indie app maker. Shipping React Native apps to the App Store — from Bible readers to AI-powered OCR.",
  image,
  type = "website",
  publishedTime
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://sambulosenda.com');

// Use OG image endpoint for blog posts, fallback to provided image or default
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const ogImage = type === 'article' && slug
  ? new URL(`/og/${slug}.png`, Astro.site || 'https://sambulosenda.com')
  : new URL(image || '/profile.jpg', Astro.site || 'https://sambulosenda.com');
---

<!doctype html>
<html lang="en" class="scroll-smooth overflow-x-hidden overscroll-none">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Sambulo Senda's Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sambulosenda" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts (self-hosted) -->

    <!-- Dark mode: blocking script to prevent flash -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <ViewTransitions />

    <style is:global>
      :root {
        --color-surface: #ffffff;
        --color-surface-muted: #fafafa;
        --color-surface-subtle: #f4f4f5;
        --color-border: #e4e4e7;
        --color-border-muted: #f4f4f5;
        --color-ink: #18181b;
        --color-ink-muted: #52525b;
        --color-ink-faint: #a1a1aa;
        --color-accent: #2563eb;
        --color-accent-hover: #1d4ed8;
        --color-accent-subtle: #eff6ff;
      }

      /* Legacy animation classes — kept for backward compat, now instant */
      .animate-fade-in-up,
      .animate-fade-in-up-delay-1,
      .animate-fade-in-up-delay-2,
      .animate-fade-in-up-delay-3,
      .animate-fade-in-up-delay-4 {
        /* These classes are being replaced by .reveal + IntersectionObserver */
        /* Keep them visible so nothing breaks during migration */
      }

      html.dark {
        --color-surface: #09090b;
        --color-surface-muted: #111113;
        --color-surface-subtle: #1c1c1f;
        --color-border: #27272a;
        --color-border-muted: #1c1c1f;
        --color-ink: #fafafa;
        --color-ink-muted: #a1a1aa;
        --color-ink-faint: #71717a;
        --color-accent: #60a5fa;
        --color-accent-hover: #93bbfd;
        --color-accent-subtle: #172554;
      }
    </style>
  </head>
  <body class="bg-surface text-ink antialiased text-base leading-relaxed font-serif">
    <slot />
    <CommandPalette />
  </body>
</html>

<script>
  // Re-apply dark mode after view transition swap
  document.addEventListener('astro:after-swap', () => {
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  });

  // Dark mode toggle
  document.addEventListener('astro:page-load', () => {
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  });

  // Scroll reveal: IntersectionObserver
  let revealObserver: IntersectionObserver | null = null;

  document.addEventListener('astro:page-load', () => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    revealObserver?.disconnect();
    revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver?.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach((el) => {
      revealObserver!.observe(el);
    });
  });

  document.addEventListener('astro:before-swap', () => {
    revealObserver?.disconnect();
  });

  // Cursor-reactive tilt (desktop only, respects reduced motion)
  let tiltRaf: number | null = null;
  let tiltHandler: ((e: MouseEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    if (!window.matchMedia('(hover: hover)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const root = document.documentElement;

    tiltHandler = (e: MouseEvent) => {
      if (tiltRaf) return;
      tiltRaf = requestAnimationFrame(() => {
        const mx = (e.clientX / window.innerWidth - 0.5) * 2;
        const my = (e.clientY / window.innerHeight - 0.5) * 2;
        root.style.setProperty('--mx', mx.toFixed(3));
        root.style.setProperty('--my', my.toFixed(3));
        tiltRaf = null;
      });
    };

    window.addEventListener('mousemove', tiltHandler, { passive: true });
  });

  document.addEventListener('astro:before-swap', () => {
    if (tiltHandler) {
      window.removeEventListener('mousemove', tiltHandler);
      tiltHandler = null;
    }
    if (tiltRaf) {
      cancelAnimationFrame(tiltRaf);
      tiltRaf = null;
    }
    document.documentElement.style.removeProperty('--mx');
    document.documentElement.style.removeProperty('--my');
  });
</script>
