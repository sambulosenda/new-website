---
import '@fontsource-variable/public-sans';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/newsreader';
import '../styles/scroll-reveal.css';
import '../styles/micro-interactions.css';
import '../styles/design.css';
import { ViewTransitions } from 'astro:transitions';
import CommandPalette from '../components/CommandPalette.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description = "Mobile engineer and indie app maker. Shipping React Native apps to the App Store — from Bible readers to AI-powered OCR.",
  image,
  type = "website",
  publishedTime
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://sambulosenda.com');

// Use OG image endpoint for blog posts, fallback to provided image or default
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const ogImage = type === 'article' && slug
  ? new URL(`/og/${slug}.png`, Astro.site || 'https://sambulosenda.com')
  : new URL(image || '/profile.jpg', Astro.site || 'https://sambulosenda.com');
---

<!doctype html>
<html lang="en" class="scroll-smooth overflow-x-hidden overscroll-none">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Sambulo Senda's Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sambulosenda" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts (self-hosted) -->

    <!-- Dark mode: blocking script to prevent flash -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <ViewTransitions />

    <style is:global>
      :root {
        /* Design palette (imported from claude.ai/design — "Sambulo Site") */
        --bg: #ffffff; --fg: #141414; --fg-strong: #000000; --body: #444444; --body-2: #555555;
        --muted: #767676; --faint: #9a9a9a; --label: #bdbdbd; --hair: #f0f0f0; --hair-2: #eeeeee;
        --chip-border: #e2e2e2; --chip-bg: #ffffff; --chip-active-bg: #141414; --chip-active-fg: #ffffff;
        --cta-fg: #141414; --cta-border: #141414; --cta-hover-bg: #141414; --cta-hover-fg: #ffffff;
        --code-bg: #f6f6f4; --code-border: #ececea; --code-fg: #333333; --accent: #1a9d5a;

        /* Aliases consumed by Tailwind tokens / legacy pages */
        --color-surface: var(--bg);
        --color-surface-muted: #fafafa;
        --color-surface-subtle: var(--code-bg);
        --color-border: var(--chip-border);
        --color-border-muted: var(--hair-2);
        --color-ink: var(--fg);
        --color-ink-muted: var(--body-2);
        --color-ink-faint: var(--muted);
        --color-accent: var(--accent);
        --color-accent-hover: #15834a;
        --color-accent-subtle: #e8f5ee;
      }

      html.dark {
        --bg: #0f0f10; --fg: #f1f1ef; --fg-strong: #ffffff; --body: #c9c9c6; --body-2: #b4b4b1;
        --muted: #8f8f8c; --faint: #6f6f6c; --label: #565654; --hair: #1f1f21; --hair-2: #232325;
        --chip-border: #2c2c2f; --chip-bg: transparent; --chip-active-bg: #f1f1ef; --chip-active-fg: #0f0f10;
        --cta-fg: #f1f1ef; --cta-border: #3a3a3d; --cta-hover-bg: #f1f1ef; --cta-hover-fg: #0f0f10;
        --code-bg: #18181a; --code-border: #2a2a2d; --code-fg: #d3d3d0;

        --color-surface-muted: #141416;
        --color-accent-hover: #34b06f;
        --color-accent-subtle: #11271c;
      }
    </style>
  </head>
  <body class="bg-surface text-ink antialiased font-sans">
    <div class="shell">
      <Sidebar />
      <div class="shell-main"><slot /></div>
    </div>
    <CommandPalette />
  </body>
</html>

<script>
  // Sync the sidebar theme-toggle pill (label + dot) to the current state
  function syncThemeToggle() {
    const isDark = document.documentElement.classList.contains('dark');
    const label = document.getElementById('tt-label');
    const dot = document.getElementById('tt-dot');
    if (label) label.textContent = isDark ? 'DARK' : 'LIGHT';
    if (dot) dot.style.background = isDark ? '#f1f1ef' : '#141414';
  }

  // Re-apply dark mode after view transition swap
  document.addEventListener('astro:after-swap', () => {
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    syncThemeToggle();
  });

  // Dark mode toggle
  document.addEventListener('astro:page-load', () => {
    syncThemeToggle();
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      syncThemeToggle();
    });
  });

  // Scroll reveal: IntersectionObserver
  let revealObserver: IntersectionObserver | null = null;

  document.addEventListener('astro:page-load', () => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    revealObserver?.disconnect();
    revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver?.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach((el) => {
      revealObserver!.observe(el);
    });
  });

  document.addEventListener('astro:before-swap', () => {
    revealObserver?.disconnect();
  });

  // Cursor-reactive tilt (desktop only, respects reduced motion)
  let tiltRaf: number | null = null;
  let tiltHandler: ((e: MouseEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    if (!window.matchMedia('(hover: hover)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const root = document.documentElement;

    tiltHandler = (e: MouseEvent) => {
      if (tiltRaf) return;
      tiltRaf = requestAnimationFrame(() => {
        const mx = (e.clientX / window.innerWidth - 0.5) * 2;
        const my = (e.clientY / window.innerHeight - 0.5) * 2;
        root.style.setProperty('--mx', mx.toFixed(3));
        root.style.setProperty('--my', my.toFixed(3));
        tiltRaf = null;
      });
    };

    window.addEventListener('mousemove', tiltHandler, { passive: true });
  });

  document.addEventListener('astro:before-swap', () => {
    if (tiltHandler) {
      window.removeEventListener('mousemove', tiltHandler);
      tiltHandler = null;
    }
    if (tiltRaf) {
      cancelAnimationFrame(tiltRaf);
      tiltRaf = null;
    }
    document.documentElement.style.removeProperty('--mx');
    document.documentElement.style.removeProperty('--my');
  });
</script>
